{:paths ["src"]
 ;; kotoba-lang/occupation supplies the shared human-gap-referral-draft fn
 ;; (ADR-2607202600) the governor uses for the :human-required disposition.
 ;; kotoba-lang/langgraph is plumbing.operation's StateGraph runtime
 ;; (zero-/single-dep, all .cljc -> portable to JVM / SCI / ClojureScript /
 ;; GraalVM, same layering as the other cloud-itonami actors, e.g.
 ;; cloud-itonami-iso3166-ago / cloud-itonami-isco-3121). This repo is
 ;; standalone (forkable outside the workspace); these :local/root paths
 ;; only resolve inside the monorepo checkout -- a standalone fork should
 ;; override them with git coordinates.
 :deps {io.github.kotoba-lang/occupation
        {:local/root "../../kotoba-lang/occupation"}
        io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain (langgraph's own
  ;; sole dep) to local checkout, same convention as every sibling actor.
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]}
  ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
